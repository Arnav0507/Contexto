# ---- Shared context REST server (packages/server) ----
# Port the REST backend listens on.
PORT=4000
# Where learnings are persisted (relative to the server package, or absolute).
SAC_DATA_FILE=./data/learnings.json

# ---- MCP server (packages/mcp) ----
# How the MCP server reaches the REST backend.
CONTEXT_SERVER_URL=http://localhost:4000
# Logical project/team namespace. Collaborators sharing context use the SAME id.
CONTEXT_PROJECT_ID=demo-project
# Who is capturing the learning. Defaults to the OS username if left blank.
CONTEXT_AUTHOR=
