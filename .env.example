# ---- Shared context REST server (packages/server) ----
# Port the REST backend listens on.
PORT=4000
# Where context commits are persisted (relative to the server package, or absolute).
SAC_DATA_FILE=./data/commits.json
# API keys required to access the backend. Empty = auth disabled (local dev).
# Comma-separated; each entry is either "key" (any project) or "key:projectId"
# (scoped to one project, for isolation). Example:
#   CONTEXT_API_KEYS=team-alpha-secret:github.com/acme/widget,admin-secret
CONTEXT_API_KEYS=

# ---- MCP server (packages/mcp) ----
# How the MCP server reaches the REST backend.
CONTEXT_SERVER_URL=http://localhost:4000
# API key sent to a hosted/shared backend (must match one in CONTEXT_API_KEYS).
# Leave blank for a local backend with auth disabled.
CONTEXT_API_KEY=
# Repo used to auto-derive the shared project id + your identity. In VS Code this
# is set to the workspace folder by .vscode/mcp.json; otherwise the process cwd.
CONTEXT_PROJECT_DIR=
# Optional manual overrides — normally auto-derived from git, so leave blank.
# CONTEXT_PROJECT_ID groups collaborators; teammates sharing context use the SAME id.
CONTEXT_PROJECT_ID=
CONTEXT_AUTHOR=
